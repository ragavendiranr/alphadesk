{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*",       "destination": "https://alphadesk-backend.onrender.com/api/:path*" },
    { "source": "/health",           "destination": "https://alphadesk-backend.onrender.com/health" },
    { "source": "/socket.io/:path*", "destination": "https://alphadesk-backend.onrender.com/socket.io/:path*" },
    { "source": "/(.*)",             "destination": "/index.html" }
  ]
}
