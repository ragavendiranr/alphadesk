# ============================================================
# ALPHADESK — Environment Variables Template
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── ZERODHA KITE CONNECT ──────────────────────────────────
ZERODHA_API_KEY=your_api_key
ZERODHA_API_SECRET=your_api_secret
ZERODHA_CLIENT_ID=your_client_id
ZERODHA_EMAIL=your_email
ZERODHA_PASSWORD=your_password
ZERODHA_TOTP_SECRET=your_totp_secret

# ── MONGODB ───────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/
MONGO_DB_NAME=Alphadesk_Trading

# ── JWT AUTH ──────────────────────────────────────────────
JWT_SECRET=change_this_to_random_256bit_string
JWT_EXPIRES_IN=7d

# ── TELEGRAM BOT ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
TELEGRAM_AUTHORIZED_USERS=your_user_id

# ── NEWS API ──────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key
TWITTER_BEARER_TOKEN=

# ── TRADING CONFIG ────────────────────────────────────────
DAILY_CAPITAL=10000
MAX_RISK_PER_TRADE=0.01
DAILY_LOSS_LIMIT=0.015
MAX_CONCURRENT_TRADES=3
ML_MIN_CONFIDENCE=75
PRODUCT_TYPE=MIS
MARKETS=NIFTY,BANKNIFTY,STOCKS

# ── SERVICE PORTS ─────────────────────────────────────────
BACKEND_PORT=4000
ML_PORT=5001
FRONTEND_PORT=3000

# ── DEPLOYMENT ────────────────────────────────────────────
NODE_ENV=production
FRONTEND_URL=https://alphadesk.vercel.app
BACKEND_URL=https://alphadesk.up.railway.app
ML_ENGINE_URL=http://localhost:5001

# ── ENCRYPTION ────────────────────────────────────────────
ENCRYPTION_KEY=change_this_32char_encryption_key
